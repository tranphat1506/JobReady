# =============================================================================
# CV Generator - Environment Variables Example
# =============================================================================
# Copy file này thành .env.local và điền các giá trị thực tế vào
# cp .env.example .env.local

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Service Role Key - chỉ dùng ở server/background jobs, KHÔNG expose ra client
# Lấy từ: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Google Gemini AI (https://aistudio.google.com/app/apikey)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# -----------------------------------------------------------------------------
# Inngest - Background Job Queue (https://app.inngest.com)
# -----------------------------------------------------------------------------
# ⚠️ LOCAL DEV: Set INNGEST_DEV=1, không cần INNGEST_SIGNING_KEY
# ⚠️ PRODUCTION: Xóa INNGEST_DEV, thêm INNGEST_SIGNING_KEY từ Inngest Dashboard

# Chỉ dùng cho local development
INNGEST_DEV=1

# Chỉ dùng cho production (lấy từ https://app.inngest.com > your app > signing key)
# INNGEST_SIGNING_KEY=signkey-prod-your_key_here

# Inngest Event Key (lấy từ Inngest Dashboard > Event Keys)
# INNGEST_EVENT_KEY=your_event_key_here
