# =============================================================================
# CV Generator - Production Environment Variables
# =============================================================================
# Dùng file này cho môi trường Production (Vercel, Railway, etc.)
# ⚠️ KHÔNG commit file này lên Git nếu chứa giá trị thực tế!
# ⚠️ Nên set các biến này trực tiếp trên dashboard của hosting provider.

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Service Role Key - dùng cho background jobs (Inngest workers)
# Lấy từ: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Google Gemini AI (https://aistudio.google.com/app/apikey)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# -----------------------------------------------------------------------------
# Inngest - Background Job Queue (https://app.inngest.com)
# -----------------------------------------------------------------------------
# Lấy từ: Inngest Dashboard > your app > Signing Keys
INNGEST_SIGNING_KEY=signkey-prod-your_key_here

# Lấy từ: Inngest Dashboard > your app > Event Keys
INNGEST_EVENT_KEY=your_event_key_here

# ⚠️ KHÔNG set INNGEST_DEV=1 trong production!

# -----------------------------------------------------------------------------
# App URL (cần thiết cho Inngest webhook callback)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-domain.com
